{
  "manifest_version": 3,
  "name": "Homer Downloader",
  "version": "1.0",
  "description": "Download X-Videos ;)",
  "permissions": ["scripting"],
  "content_scripts": [
    {
      "matches": [
        "*://*.twitter.com/*",
        "*://*.x.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}